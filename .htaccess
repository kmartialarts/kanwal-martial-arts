# ============================================================
# KANWAL MARTIAL ARTS ACADEMY — Apache .htaccess
# ============================================================

Options -Indexes
ServerSignature Off

# ============================================================
# FORCE HTTPS
# ============================================================
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ============================================================
# CANONICAL DOMAIN — Redirect to kanwalmartialarts.gt.tc
# ============================================================
RewriteCond %{HTTP_HOST} !^kanwalmartialarts\.gt\.tc$ [NC]
RewriteRule ^(.*)$ https://kanwalmartialarts.gt.tc/$1 [R=301,L]

# ============================================================
# CLEAN URLS — Remove .html Extension
# ============================================================
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]

# Remove .html from URL
RewriteCond %{THE_REQUEST} /([^.]+)\.html [NC]
RewriteRule ^ /%1 [NC,L,R=301]

# ============================================================
# DIRECTORY CLEAN URLS (Folder/index.html → /folder/)
# ============================================================
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([a-z-]+)/?$ /$1/index.html [L]

# ============================================================
# TRAILING SLASH REDIRECT
# ============================================================
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_URI} !/$
RewriteRule ^(.+[^/])$ %{REQUEST_URI}/ [L,R=301]

# ============================================================
# SECURITY HEADERS
# ============================================================
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
    Header always set Content-Security-Policy "default-src 'self' https: data: 'unsafe-inline' 'unsafe-eval'; img-src 'self' https: data:; font-src 'self' https: data:;"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
</IfModule>

# ============================================================
# BROWSER CACHING
# ============================================================
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"

    # HTML
    ExpiresByType text/html "access plus 1 hour"

    # CSS
    ExpiresByType text/css "access plus 1 year"

    # JavaScript
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType text/javascript "access plus 1 year"

    # Images
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"

    # Fonts
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"

    # Data
    ExpiresByType application/json "access plus 0 seconds"
    ExpiresByType application/xml "access plus 0 seconds"
    ExpiresByType text/xml "access plus 0 seconds"
</IfModule>

# Cache-Control Headers
<IfModule mod_headers.c>
    <FilesMatch "\.(css|js|woff|woff2|ttf|eot)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico)$">
        Header set Cache-Control "public, max-age=31536000"
    </FilesMatch>
    <FilesMatch "\.(html|htm)$">
        Header set Cache-Control "public, max-age=3600, must-revalidate"
    </FilesMatch>
</IfModule>

# ============================================================
# GZIP COMPRESSION
# ============================================================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/ld+json
    AddOutputFilterByType DEFLATE image/svg+xml
    AddOutputFilterByType DEFLATE font/woff
    AddOutputFilterByType DEFLATE font/woff2
    AddOutputFilterByType DEFLATE application/font-woff
    AddOutputFilterByType DEFLATE application/font-woff2
</IfModule>

# Brotli if available
<IfModule mod_brotli.c>
    AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/xml text/css
    AddOutputFilterByType BROTLI_COMPRESS application/javascript application/json
    AddOutputFilterByType BROTLI_COMPRESS image/svg+xml font/woff font/woff2
</IfModule>

# ============================================================
# KEEP-ALIVE
# ============================================================
<IfModule mod_headers.c>
    Header set Connection keep-alive
</IfModule>

# ============================================================
# ERROR PAGES
# ============================================================
ErrorDocument 404 /index.html
ErrorDocument 403 /index.html
ErrorDocument 500 /index.html

# ============================================================
# BLOCK BAD BOTS & PROTECT SENSITIVE FILES
# ============================================================
<FilesMatch "(^#.*#|\.(bak|conf|dist|fla|inc|ini|log|psd|sh|sql|sw[op]|tmp|md|txt|backup|old|orig|archive|zip|tar|gz|rar|7z)|~)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Protect .htaccess, backup folders, and config files
<Files .htaccess>
    Order allow,deny
    Deny from all
</Files>

<DirectoryMatch "^.*(backup|backups|\.backup|\.git|\.svn|node_modules|temp|tmp).*$">
    Order allow,deny
    Deny from all
</DirectoryMatch>

# ============================================================
# PREVENT HOTLINKING OF MEDIA FILES
# ============================================================
<IfModule mod_rewrite.c>
    RewriteCond %{HTTP_REFERER} !^$
    RewriteCond %{HTTP_REFERER} !^https?://kanwalmartialarts\.gt\.tc [NC]
    RewriteRule \.(jpg|jpeg|png|gif|webp|pdf|mp4|webm)$ - [F,NC]
</IfModule>

# ============================================================
# BLOCK MALICIOUS REQUEST PATTERNS
# ============================================================
<IfModule mod_rewrite.c>
    # Block SQL injection attempts
    RewriteCond %{QUERY_STRING} (\%27)|(\')|(\-\-)|(\%23)|(#) [NC]
    RewriteRule ^(.*)$ - [F]
    
    # Block XSS attempts
    RewriteCond %{QUERY_STRING} (\<)|(script)|(eval)|(onclick) [NC]
    RewriteRule ^(.*)$ - [F]
    
    # Block path traversal attempts
    RewriteCond %{REQUEST_URI} \.\. [NC]
    RewriteRule ^(.*)$ - [F]
    
    # Block common exploit attempts
    RewriteCond %{QUERY_STRING} (union|select|insert|update|delete|drop|create|alter) [NC]
    RewriteRule ^(.*)$ - [F]
</IfModule>

# ============================================================
# MIME TYPES
# ============================================================
<IfModule mod_mime.c>
    AddType application/javascript .js
    AddType text/css .css
    AddType image/webp .webp
    AddType font/woff .woff
    AddType font/woff2 .woff2
    AddType image/svg+xml .svg
    AddType application/json .json
</IfModule>

# ============================================================
# ENABLE MOD_REWRITE
# ============================================================
<IfModule mod_rewrite.c>
    RewriteEngine On
    Options +FollowSymLinks -MultiViews
</IfModule>
